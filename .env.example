# Server Configuration
PORT=8080

# Database Configuration (PostgreSQL/Neon)
DB_URL=jdbc:postgresql://ep-bitter-heart-anncmfld-pooler.c-6.us-east-1.aws.neon.tech/neondb?sslmode=require
DB_USERNAME=neondb_owner
DB_PASSWORD=your_secure_db_password

# Authentication (Must be overridden in Production)
JWT_SECRET=super_secret_key_that_is_at_least_256_bits_long_for_security_reasons
JWT_EXPIRATION_MS=86400000

# Hibernate / Flyway
DDL_AUTO=none
SHOW_SQL=false
FLYWAY_ENABLED=true

# Logging
LOG_LEVEL=INFO
SECURITY_LOG_LEVEL=WARN
APP_LOG_LEVEL=INFO
